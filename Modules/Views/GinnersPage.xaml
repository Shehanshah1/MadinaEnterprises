<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MadinaEnterprises.Modules.Views.GinnersPage"
             Title=""
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False"
             MinimumHeightRequest="600"
             MinimumWidthRequest="1200">

    <Grid ColumnDefinitions="260,*">

        <!-- Sidebar -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SidebarBackground}">
            <Grid RowDefinitions="Auto,*,Auto" Padding="16,24">
                <VerticalStackLayout Grid.Row="0" Spacing="14" Margin="8,0,8,24">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Frame BackgroundColor="#1E293B" BorderColor="#334155"
                               CornerRadius="10" Padding="8" HasShadow="False"
                               HeightRequest="42" WidthRequest="42">
                            <Image Source="madina_logo.png" Aspect="AspectFit"/>
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                            <Label Text="MADINA" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource SidebarBrandText}"
                                   FontSize="14" CharacterSpacing="3"/>
                            <Label Text="Enterprises"
                                   TextColor="{StaticResource SidebarBrandAccent}"
                                   FontSize="11" CharacterSpacing="2"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="WORKSPACE" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,0,0,6"/>
                        <Button Text="Dashboard"  Style="{StaticResource SidebarItem}"       Clicked="OnDashboardPageButtonClicked"/>
                        <Button Text="Ginners"    Style="{StaticResource SidebarItemActive}"/>
                        <Button Text="Mills"      Style="{StaticResource SidebarItem}"       Clicked="OnMillsPageButtonClicked"/>
                        <Button Text="Contracts"  Style="{StaticResource SidebarItem}"       Clicked="OnContractsPageButtonClicked"/>
                        <Button Text="Deliveries" Style="{StaticResource SidebarItem}"       Clicked="OnDeliveriesPageButtonClicked"/>
                        <Button Text="Payments"   Style="{StaticResource SidebarItem}"       Clicked="OnPaymentsPageButtonClicked"/>

                        <Label Text="REPORTS" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,16,0,6"/>
                        <Button Text="Ginner Ledger" Style="{StaticResource SidebarItem}" Clicked="OnGinnerLedgerPageButtonClicked"/>
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                    <Button Text="Log out" Style="{StaticResource SidebarLogout}" Clicked="OnLogOutButtonClicked"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Main -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="36,32" Spacing="24">

                <VerticalStackLayout Spacing="4">
                    <Label Text="DIRECTORY" Style="{StaticResource Eyebrow}"/>
                    <Label Text="Ginner management" Style="{StaticResource PageTitle}"/>
                    <Label Text="Create, update and maintain your ginner records."
                           Style="{StaticResource PageSubtitle}"/>
                </VerticalStackLayout>

                <!-- Form Card -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="18">
                        <Label Text="Ginner details" Style="{StaticResource SectionTitle}"/>

                        <Grid ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="18"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="Ginner ID" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerIDEntry" Placeholder="e.g., GNR-001"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                <Label Text="Ginner name" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerNameEntry" Placeholder="e.g., Al-Noor Ginning"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                <Label Text="Contact" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerContactEntry" Placeholder="Phone / Email"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                <Label Text="Contact person" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerContactPersonEntry" Placeholder="Contact person name"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                                <Label Text="IBAN" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerIBANEntry" Placeholder="IBAN #"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                                <Label Text="Bank address" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerBankAddressEntry" Placeholder="Bank branch address"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
                                <Label Text="NTN" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerNTNEntry" Placeholder="NTN #"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="3" Grid.Column="1" Spacing="6">
                                <Label Text="STN" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerSTNEntry" Placeholder="STN #"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="4" Grid.Column="0" Spacing="6">
                                <Label Text="Address" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerAddressEntry" Placeholder="Street, City"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="4" Grid.Column="1" Spacing="6">
                                <Label Text="Station" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="GinnerStationEntry" Placeholder="Station / City"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView Style="{StaticResource Divider}" Margin="0,4"/>

                        <FlexLayout Wrap="Wrap" JustifyContent="End" AlignItems="Center">
                            <Button Text="Delete" Style="{StaticResource DangerButton}"   Margin="0,0,8,8" Clicked="OnDeleteGinnerClicked"/>
                            <Button Text="Update" Style="{StaticResource WarningButton}"  Margin="0,0,8,8" Clicked="OnUpdateGinnerClicked"/>
                            <Button Text="Add ginner" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Clicked="OnAddGinnerClicked"/>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Listing -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Existing ginners" Style="{StaticResource SectionTitle}"/>
                                <Label Text="Select a ginner to edit or delete."
                                       Style="{StaticResource PageSubtitle}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Frame BackgroundColor="{StaticResource Neutral50}"
                               BorderColor="{StaticResource BorderStrong}"
                               CornerRadius="10" Padding="4" HasShadow="False">
                            <SearchBar x:Name="GinnerSearchBar"
                                       Placeholder="Search by Ginner Name or ID..."
                                       TextChanged="OnSearchTextChanged"
                                       BackgroundColor="Transparent"/>
                        </Frame>

                        <ListView x:Name="GinnersListView"
                                  BackgroundColor="Transparent"
                                  SelectionMode="Single"
                                  ItemSelected="OnGinnerSelected"
                                  HasUnevenRows="True"
                                  SeparatorVisibility="None"
                                  HeightRequest="320">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Frame Style="{StaticResource ListCard}">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="14">
                                                <Frame Grid.RowSpan="2" Grid.Column="0"
                                                       BackgroundColor="{StaticResource Brand50}"
                                                       BorderColor="{StaticResource Brand200}"
                                                       CornerRadius="8"
                                                       Padding="10,8"
                                                       HasShadow="False"
                                                       VerticalOptions="Center">
                                                    <Label Text="G"
                                                           FontFamily="OpenSansSemibold"
                                                           FontSize="18"
                                                           TextColor="{StaticResource Brand700}"
                                                           HorizontalOptions="Center"/>
                                                </Frame>
                                                <Label Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding GinnerName}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource TextPrimary}"/>
                                                <Label Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding Contact}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextMuted}"/>
                                                <Label Grid.RowSpan="2" Grid.Column="2"
                                                       Text="{Binding GinnerID}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="{StaticResource Brand700}"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                        </Frame>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
