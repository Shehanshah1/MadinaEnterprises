<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MadinaEnterprises.Modules.Views.LoginPage"
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False"
             MinimumHeightRequest="700"
             MinimumWidthRequest="1000">

    <Grid>
        <!-- Soft brand accent strip at top -->
        <BoxView VerticalOptions="Start"
                 HeightRequest="6"
                 BackgroundColor="{StaticResource Brand400}"/>

        <ScrollView>
            <Grid Padding="40,60"
                  RowDefinitions="Auto,*,Auto"
                  HorizontalOptions="Center"
                  MaximumWidthRequest="1040">

                <!-- Brand row -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="14"
                      Margin="0,0,0,32">
                    <Frame Grid.Column="0"
                           BackgroundColor="{StaticResource Brand50}"
                           BorderColor="{StaticResource Brand200}"
                           CornerRadius="12"
                           Padding="10"
                           HasShadow="False"
                           HeightRequest="56"
                           WidthRequest="56">
                        <Image Source="madina_logo.png"
                               Aspect="AspectFit"/>
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="MADINA ENTERPRISES"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               CharacterSpacing="4"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Trusted Cotton Trading Platform"
                               Style="{StaticResource Caption}"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Login card -->
                <Frame Grid.Row="1"
                       Style="{StaticResource Card}"
                       Padding="0"
                       HorizontalOptions="Center"
                       WidthRequest="920">

                    <Grid ColumnDefinitions="1.05*,1*" RowDefinitions="*">

                        <!-- Left: brand panel -->
                        <Grid Grid.Column="0"
                              BackgroundColor="{StaticResource Neutral900}"
                              Padding="40,48">
                            <BoxView BackgroundColor="{StaticResource Brand400}"
                                     HorizontalOptions="Start"
                                     VerticalOptions="Start"
                                     HeightRequest="64"
                                     WidthRequest="4"
                                     Margin="0,8,0,0"/>

                            <VerticalStackLayout Spacing="20"
                                                 VerticalOptions="Center"
                                                 Margin="16,0,0,0">
                                <Label Text="Welcome back."
                                       FontFamily="OpenSansSemibold"
                                       FontSize="34"
                                       TextColor="#FFFFFF"/>
                                <Label Text="Manage ginners, contracts, deliveries and payments from one clean workspace."
                                       FontSize="15"
                                       TextColor="#CBD5E1"
                                       LineHeight="1.4"/>

                                <VerticalStackLayout Spacing="10" Margin="0,24,0,0">
                                    <HorizontalStackLayout Spacing="10">
                                        <BoxView BackgroundColor="{StaticResource Brand400}"
                                                 WidthRequest="6" HeightRequest="6"
                                                 VerticalOptions="Center"/>
                                        <Label Text="Unified ginner ledger &amp; dashboards"
                                               TextColor="#E2E8F0" FontSize="13"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="10">
                                        <BoxView BackgroundColor="{StaticResource Brand400}"
                                                 WidthRequest="6" HeightRequest="6"
                                                 VerticalOptions="Center"/>
                                        <Label Text="Cloud-synced records across devices"
                                               TextColor="#E2E8F0" FontSize="13"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="10">
                                        <BoxView BackgroundColor="{StaticResource Brand400}"
                                                 WidthRequest="6" HeightRequest="6"
                                                 VerticalOptions="Center"/>
                                        <Label Text="Export to DOCX and Excel in one click"
                                               TextColor="#E2E8F0" FontSize="13"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Right: form -->
                        <VerticalStackLayout Grid.Column="1"
                                             Padding="44,48"
                                             Spacing="18"
                                             VerticalOptions="Center">

                            <Label Text="SIGN IN" Style="{StaticResource Eyebrow}"/>
                            <Label Text="Access your workspace"
                                   Style="{StaticResource PageTitle}"/>
                            <Label Text="Enter your admin credentials to continue."
                                   Style="{StaticResource PageSubtitle}"
                                   Margin="0,-8,0,8"/>

                            <!-- Error Message -->
                            <Frame x:Name="errorFrame"
                                   IsVisible="False"
                                   BackgroundColor="{StaticResource DangerBg}"
                                   BorderColor="{StaticResource Danger}"
                                   Padding="12,10"
                                   CornerRadius="8">
                                <Label x:Name="errorMessageLabel"
                                       TextColor="{StaticResource Danger}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"/>
                            </Frame>

                            <!-- Username -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Username" Style="{StaticResource FormLabel}"/>
                                <Frame Padding="12,2"
                                       BackgroundColor="{StaticResource Neutral50}"
                                       BorderColor="{StaticResource BorderStrong}"
                                       CornerRadius="8"
                                       HasShadow="False">
                                    <Entry x:Name="emailEntry"
                                           Placeholder="Enter your username"
                                           BackgroundColor="Transparent"
                                           HeightRequest="42"/>
                                </Frame>
                            </VerticalStackLayout>

                            <!-- Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Password" Style="{StaticResource FormLabel}"/>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Frame Grid.Column="0"
                                           Padding="12,2"
                                           BackgroundColor="{StaticResource Neutral50}"
                                           BorderColor="{StaticResource BorderStrong}"
                                           CornerRadius="8"
                                           HasShadow="False">
                                        <Entry x:Name="passwordEntry"
                                               Placeholder="Enter your password"
                                               IsPassword="True"
                                               BackgroundColor="Transparent"
                                               HeightRequest="42"/>
                                    </Frame>
                                    <Button x:Name="showHidePasswordButton"
                                            Grid.Column="1"
                                            Text="Show"
                                            Style="{StaticResource SecondaryButton}"
                                            Clicked="showHidePasswordButton_Clicked"/>
                                </Grid>
                            </VerticalStackLayout>

                            <Button x:Name="loginButton"
                                    Text="Sign in"
                                    Style="{StaticResource PrimaryButton}"
                                    HeightRequest="48"
                                    FontSize="15"
                                    Margin="0,8,0,0"
                                    Clicked="OnLoginButtonClicked"/>

                            <Label Text="Protected by your administrator. Contact support if you cannot sign in."
                                   Style="{StaticResource Caption}"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,4,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <Label Grid.Row="2"
                       Text="© Madina Enterprises · Internal use only"
                       Style="{StaticResource Caption}"
                       HorizontalOptions="Center"
                       Margin="0,28,0,0"/>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
