<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MadinaEnterprises.Modules.Views.PaymentsPage"
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False"
             MinimumHeightRequest="600"
             MinimumWidthRequest="1200">

    <Grid ColumnDefinitions="260,*">

        <!-- Sidebar -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SidebarBackground}">
            <Grid RowDefinitions="Auto,*,Auto" Padding="16,24">
                <VerticalStackLayout Grid.Row="0" Spacing="14" Margin="8,0,8,24">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Frame BackgroundColor="#1E293B" BorderColor="#334155"
                               CornerRadius="10" Padding="8" HasShadow="False"
                               HeightRequest="42" WidthRequest="42">
                            <Image Source="madina_logo.png" Aspect="AspectFit"/>
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                            <Label Text="MADINA" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource SidebarBrandText}"
                                   FontSize="14" CharacterSpacing="3"/>
                            <Label Text="Enterprises"
                                   TextColor="{StaticResource SidebarBrandAccent}"
                                   FontSize="11" CharacterSpacing="2"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="WORKSPACE" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,0,0,6"/>
                        <Button Text="Dashboard"  Style="{StaticResource SidebarItem}" Clicked="OnDashboardPageButtonClicked"/>
                        <Button Text="Ginners"    Style="{StaticResource SidebarItem}" Clicked="OnGinnersPageButtonClicked"/>
                        <Button Text="Mills"      Style="{StaticResource SidebarItem}" Clicked="OnMillsPageButtonClicked"/>
                        <Button Text="Contracts"  Style="{StaticResource SidebarItem}" Clicked="OnContractsPageButtonClicked"/>
                        <Button Text="Deliveries" Style="{StaticResource SidebarItem}" Clicked="OnDeliveriesPageButtonClicked"/>
                        <Button Text="Payments"   Style="{StaticResource SidebarItemActive}"/>

                        <Label Text="REPORTS" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,16,0,6"/>
                        <Button Text="Ginner Ledger" Style="{StaticResource SidebarItem}" Clicked="OnGinnerLedgerPageButtonClicked"/>
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                    <Button Text="Log out" Style="{StaticResource SidebarLogout}" Clicked="OnLogOutButtonClicked"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Main -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="36,32" Spacing="24">

                <VerticalStackLayout Spacing="4">
                    <Label Text="FINANCE" Style="{StaticResource Eyebrow}"/>
                    <Label Text="Payment management" Style="{StaticResource PageTitle}"/>
                    <Label Text="Log payments made against contracts and track balances."
                           Style="{StaticResource PageSubtitle}"/>
                </VerticalStackLayout>

                <!-- Hidden picker (code-behind compatibility) -->
                <Picker x:Name="paymentPicker"
                        Title="Select Payment to Edit/Delete"
                        SelectedIndexChanged="OnPaymentSelected"
                        IsVisible="False"/>

                <!-- Form -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="18">
                        <Label Text="Payment details" Style="{StaticResource SectionTitle}"/>

                        <Grid ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="18"
                              RowDefinitions="Auto,Auto,Auto,Auto">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="Payment ID" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="paymentIDEntry" Placeholder="Payment ID"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                <Label Text="Contract" Style="{StaticResource FormLabel}"/>
                                <Picker x:Name="contractPicker"
                                        Title="Select contract"
                                        SelectedIndexChanged="OnContractChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                <Label Text="Total amount" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="totalAmountEntry"
                                       Placeholder="Suggested, editable"
                                       Keyboard="Numeric"
                                       TextChanged="OnTotalAmountChanged"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                <Label Text="Amount paid" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="paidAmountEntry"
                                       Placeholder="Amount paid"
                                       Keyboard="Numeric"
                                       TextChanged="OnPaidAmountChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                                <Label Text="Remaining amount" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="remainingAmountEntry"
                                       Placeholder="Remaining amount"
                                       IsReadOnly="True"
                                       BackgroundColor="{StaticResource Neutral100}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                                <Label Text="Total bales" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="balesEntry" Placeholder="Total bales" Keyboard="Numeric"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
                                <Label Text="Payment date" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="paymentDatePicker"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView Style="{StaticResource Divider}" Margin="0,4"/>

                        <FlexLayout Wrap="Wrap" JustifyContent="End" AlignItems="Center">
                            <Button Text="Delete"         Style="{StaticResource DangerButton}"  Margin="0,0,8,8" Clicked="OnDeletePaymentClicked"/>
                            <Button Text="Update payment" Style="{StaticResource WarningButton}" Margin="0,0,8,8" Clicked="OnUpdatePaymentClicked"/>
                            <Button Text="Save payment"   Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Clicked="OnSavePaymentClicked"/>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Listing -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Existing payments" Style="{StaticResource SectionTitle}"/>
                            <Label Text="Select a payment to edit or remove."
                                   Style="{StaticResource PageSubtitle}"/>
                        </VerticalStackLayout>

                        <Frame BackgroundColor="{StaticResource Neutral50}"
                               BorderColor="{StaticResource BorderStrong}"
                               CornerRadius="10" Padding="4" HasShadow="False">
                            <SearchBar x:Name="paymentSearchBar"
                                       Placeholder="Search Payment ID..."
                                       TextChanged="OnSearchTextChanged"
                                       BackgroundColor="Transparent"/>
                        </Frame>

                        <CollectionView x:Name="paymentListView"
                                        BackgroundColor="Transparent"
                                        HeightRequest="320"
                                        SelectionMode="Single"
                                        SelectionChanged="OnPaymentListSelected">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Style="{StaticResource ListCard}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="{StaticResource SuccessBg}"
                                                   BorderColor="#BBF7D0"
                                                   CornerRadius="8"
                                                   Padding="10,8"
                                                   HasShadow="False"
                                                   VerticalOptions="Center">
                                                <Label Text="₨"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="16"
                                                       TextColor="{StaticResource Success}"
                                                       HorizontalOptions="Center"/>
                                            </Frame>
                                            <Label Grid.Column="1"
                                                   Text="{Binding PaymentID}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="2"
                                                   Text="View"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Success}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
