<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MadinaEnterprises.Modules.Views.ContractsPage"
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False"
             MinimumHeightRequest="600"
             MinimumWidthRequest="1200">

    <Grid ColumnDefinitions="260,*">

        <!-- Sidebar -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SidebarBackground}">
            <Grid RowDefinitions="Auto,*,Auto" Padding="16,24">
                <VerticalStackLayout Grid.Row="0" Spacing="14" Margin="8,0,8,24">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Frame BackgroundColor="#1E293B" BorderColor="#334155"
                               CornerRadius="10" Padding="8" HasShadow="False"
                               HeightRequest="42" WidthRequest="42">
                            <Image Source="madina_logo.png" Aspect="AspectFit"/>
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                            <Label Text="MADINA" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource SidebarBrandText}"
                                   FontSize="14" CharacterSpacing="3"/>
                            <Label Text="Enterprises"
                                   TextColor="{StaticResource SidebarBrandAccent}"
                                   FontSize="11" CharacterSpacing="2"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="WORKSPACE" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,0,0,6"/>
                        <Button Text="Dashboard"  Style="{StaticResource SidebarItem}" Clicked="OnDashboardPageButtonClicked"/>
                        <Button Text="Ginners"    Style="{StaticResource SidebarItem}" Clicked="OnGinnersPageButtonClicked"/>
                        <Button Text="Mills"      Style="{StaticResource SidebarItem}" Clicked="OnMillsPageButtonClicked"/>
                        <Button Text="Contracts"  Style="{StaticResource SidebarItemActive}"/>
                        <Button Text="Deliveries" Style="{StaticResource SidebarItem}" Clicked="OnDeliveriesPageButtonClicked"/>
                        <Button Text="Payments"   Style="{StaticResource SidebarItem}" Clicked="OnPaymentsPageButtonClicked"/>

                        <Label Text="REPORTS" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,16,0,6"/>
                        <Button Text="Ginner Ledger" Style="{StaticResource SidebarItem}" Clicked="OnGinnerLedgerPageButtonClicked"/>
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                    <Button Text="Log out" Style="{StaticResource SidebarLogout}" Clicked="OnLogOutButtonClicked"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Main -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="36,32" Spacing="24">

                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="AGREEMENTS" Style="{StaticResource Eyebrow}"/>
                        <Label Text="Contract management" Style="{StaticResource PageTitle}"/>
                        <Label Text="Record sales agreements between ginners and mills."
                               Style="{StaticResource PageSubtitle}"/>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                        <Button Text="Export DOCX" Style="{StaticResource SecondaryButton}" Clicked="OnExportDocClicked"/>
                        <Button Text="Export Excel" Style="{StaticResource SecondaryButton}" Clicked="OnExportExcelClicked"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Contract selector (kept for compatibility, hidden by code-behind) -->
                <Picker x:Name="contractPicker"
                        Title="Select Contract to Edit/Delete"
                        IsVisible="False"/>

                <!-- Form Card -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="18">
                        <Label Text="Contract details" Style="{StaticResource SectionTitle}"/>

                        <Grid ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="18"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="Contract ID" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="contractIDEntry" Placeholder="Contract ID"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                <Label Text="Contract date" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="contractDatePicker"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                <Label Text="Ginner" Style="{StaticResource FormLabel}"/>
                                <Picker x:Name="ginnerPicker" Title="Select ginner"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                <Label Text="Mill" Style="{StaticResource FormLabel}"/>
                                <Picker x:Name="millPicker" Title="Select mill"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                                <Label Text="Amount" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="amountEntry" Placeholder="Amount" Keyboard="Numeric"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                                <Label Text="Total bales" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="totalBalesEntry" Placeholder="Total bales" Keyboard="Numeric"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
                                <Label Text="Price per batch" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="pricePerBatchEntry" Placeholder="Price per batch" Keyboard="Numeric"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="3" Grid.Column="1" Spacing="6">
                                <Label Text="Commission (%)" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="commissionEntry" Placeholder="Commission percentage" Keyboard="Numeric"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                                <Label Text="Description" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="descriptionEntry" Placeholder="Composition, percentage, notes"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="5" Grid.Column="0" Spacing="6">
                                <Label Text="Delivery notes" Style="{StaticResource FormLabel}"/>
                                <Editor x:Name="deliveryNotesEditor"
                                        Placeholder="Delivery notes"
                                        AutoSize="TextChanges"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="5" Grid.Column="1" Spacing="6">
                                <Label Text="Payment notes" Style="{StaticResource FormLabel}"/>
                                <Editor x:Name="paymentNotesEditor"
                                        Placeholder="Payment notes"
                                        AutoSize="TextChanges"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView Style="{StaticResource Divider}" Margin="0,4"/>

                        <FlexLayout Wrap="Wrap" JustifyContent="End" AlignItems="Center">
                            <Button Text="Delete"          Style="{StaticResource DangerButton}"  Margin="0,0,8,8" Clicked="OnDeleteContractClicked"/>
                            <Button Text="Update contract" Style="{StaticResource WarningButton}" Margin="0,0,8,8" Clicked="OnUpdateContractClicked"/>
                            <Button Text="Save contract"   Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Clicked="OnSaveContractClicked"/>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Listing -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Existing contracts" Style="{StaticResource SectionTitle}"/>
                            <Label Text="Select a contract to edit or delete."
                                   Style="{StaticResource PageSubtitle}"/>
                        </VerticalStackLayout>

                        <Frame BackgroundColor="{StaticResource Neutral50}"
                               BorderColor="{StaticResource BorderStrong}"
                               CornerRadius="10" Padding="4" HasShadow="False">
                            <SearchBar x:Name="contractSearchBar"
                                       Placeholder="Search Contract ID..."
                                       TextChanged="OnSearchTextChanged"
                                       BackgroundColor="Transparent"/>
                        </Frame>

                        <CollectionView x:Name="contractListView"
                                        BackgroundColor="Transparent"
                                        HeightRequest="320"
                                        SelectionMode="Single"
                                        SelectionChanged="OnContractListSelected"
                                        Margin="0,0,0,4">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Style="{StaticResource ListCard}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="{StaticResource Brand50}"
                                                   BorderColor="{StaticResource Brand200}"
                                                   CornerRadius="8"
                                                   Padding="10,8"
                                                   HasShadow="False"
                                                   VerticalOptions="Center">
                                                <Label Text="C"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="16"
                                                       TextColor="{StaticResource Brand700}"
                                                       HorizontalOptions="Center"/>
                                            </Frame>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding ContractID}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource TextPrimary}"/>
                                                <Label FontSize="12"
                                                       TextColor="{StaticResource TextMuted}">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding GinnerName}" />
                                                            <Span Text="  ·  "/>
                                                            <Span Text="{Binding GinnerID}"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2"
                                                   Text="View"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Brand700}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
