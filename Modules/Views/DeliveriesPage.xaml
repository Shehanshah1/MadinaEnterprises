<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MadinaEnterprises.Modules.Views.DeliveriesPage"
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False"
             MinimumHeightRequest="600"
             MinimumWidthRequest="1200">

    <Grid ColumnDefinitions="260,*">

        <!-- Sidebar -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SidebarBackground}">
            <Grid RowDefinitions="Auto,*,Auto" Padding="16,24">
                <VerticalStackLayout Grid.Row="0" Spacing="14" Margin="8,0,8,24">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Frame BackgroundColor="#1E293B" BorderColor="#334155"
                               CornerRadius="10" Padding="8" HasShadow="False"
                               HeightRequest="42" WidthRequest="42">
                            <Image Source="madina_logo.png" Aspect="AspectFit"/>
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                            <Label Text="MADINA" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource SidebarBrandText}"
                                   FontSize="14" CharacterSpacing="3"/>
                            <Label Text="Enterprises"
                                   TextColor="{StaticResource SidebarBrandAccent}"
                                   FontSize="11" CharacterSpacing="2"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="WORKSPACE" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,0,0,6"/>
                        <Button Text="Dashboard"  Style="{StaticResource SidebarItem}" Clicked="OnDashboardPageButtonClicked"/>
                        <Button Text="Ginners"    Style="{StaticResource SidebarItem}" Clicked="OnGinnersPageButtonClicked"/>
                        <Button Text="Mills"      Style="{StaticResource SidebarItem}" Clicked="OnMillsPageButtonClicked"/>
                        <Button Text="Contracts"  Style="{StaticResource SidebarItem}" Clicked="OnContractsPageButtonClicked"/>
                        <Button Text="Deliveries" Style="{StaticResource SidebarItemActive}"/>
                        <Button Text="Payments"   Style="{StaticResource SidebarItem}" Clicked="OnPaymentsPageButtonClicked"/>

                        <Label Text="REPORTS" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,16,0,6"/>
                        <Button Text="Ginner Ledger" Style="{StaticResource SidebarItem}" Clicked="OnGinnerLedgerPageButtonClicked"/>
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                    <Button Text="Log out" Style="{StaticResource SidebarLogout}" Clicked="OnLogOutButtonClicked"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Main -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="36,32" Spacing="24">

                <VerticalStackLayout Spacing="4">
                    <Label Text="LOGISTICS" Style="{StaticResource Eyebrow}"/>
                    <Label Text="Delivery management" Style="{StaticResource PageTitle}"/>
                    <Label Text="Record deliveries against open contracts."
                           Style="{StaticResource PageSubtitle}"/>
                </VerticalStackLayout>

                <!-- Hidden picker kept for code-behind compatibility -->
                <Picker x:Name="deliveryPicker"
                        Title="Select Delivery to Edit/Delete"
                        SelectedIndexChanged="OnDeliverySelected"
                        IsVisible="False"/>

                <!-- Form -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="18">
                        <Label Text="Delivery details" Style="{StaticResource SectionTitle}"/>

                        <Grid ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="18"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="Delivery ID" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="deliveryIDEntry" Placeholder="Delivery ID"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                <Label Text="Contract" Style="{StaticResource FormLabel}"/>
                                <Picker x:Name="contractPicker"
                                        Title="Select contract"
                                        SelectedIndexChanged="OnContractChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                <Label Text="Amount" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="amountEntry"
                                       Placeholder="Suggested from mill weight, editable"
                                       Keyboard="Numeric"
                                       TextChanged="OnAmountChanged"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                <Label Text="Total bales" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="totalBalesEntry" Placeholder="Total bales" Keyboard="Numeric"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                                <Label Text="Factory weight" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="factoryWeightEntry" Placeholder="Factory weight" Keyboard="Numeric"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                                <Label Text="Mill weight (kg)" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="millWeightEntry"
                                       Placeholder="Mill weight (kg)"
                                       Keyboard="Numeric"
                                       TextChanged="OnMillWeightChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
                                <Label Text="Truck number" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="truckNoEntry" Placeholder="Truck number"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="3" Grid.Column="1" Spacing="6">
                                <Label Text="Driver contact" Style="{StaticResource FormLabel}"/>
                                <Entry x:Name="driverContactEntry" Placeholder="Driver contact" Keyboard="Telephone"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="4" Grid.Column="0" Spacing="6">
                                <Label Text="Departure date" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="departureDatePicker"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="4" Grid.Column="1" Spacing="6">
                                <Label Text="Delivery date" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="deliveryDatePicker"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView Style="{StaticResource Divider}" Margin="0,4"/>

                        <FlexLayout Wrap="Wrap" JustifyContent="End" AlignItems="Center">
                            <Button Text="Delete"          Style="{StaticResource DangerButton}"  Margin="0,0,8,8" Clicked="OnDeleteDeliveryClicked"/>
                            <Button Text="Update delivery" Style="{StaticResource WarningButton}" Margin="0,0,8,8" Clicked="OnUpdateDeliveryClicked"/>
                            <Button Text="Save delivery"   Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Clicked="OnSaveDeliveryClicked"/>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Listing -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Existing deliveries" Style="{StaticResource SectionTitle}"/>
                            <Label Text="Select a delivery to edit or remove."
                                   Style="{StaticResource PageSubtitle}"/>
                        </VerticalStackLayout>

                        <Frame BackgroundColor="{StaticResource Neutral50}"
                               BorderColor="{StaticResource BorderStrong}"
                               CornerRadius="10" Padding="4" HasShadow="False">
                            <SearchBar x:Name="deliverySearchBar"
                                       Placeholder="Search by Delivery ID..."
                                       TextChanged="OnSearchTextChanged"
                                       BackgroundColor="Transparent"/>
                        </Frame>

                        <CollectionView x:Name="deliveryListView"
                                        BackgroundColor="Transparent"
                                        HeightRequest="320"
                                        SelectionMode="Single"
                                        SelectionChanged="OnDeliveryListSelected"
                                        Margin="0,0,0,4">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Style="{StaticResource ListCard}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="{StaticResource InfoBg}"
                                                   BorderColor="#BFDBFE"
                                                   CornerRadius="8"
                                                   Padding="10,8"
                                                   HasShadow="False"
                                                   VerticalOptions="Center">
                                                <Label Text="D"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="16"
                                                       TextColor="{StaticResource Info}"
                                                       HorizontalOptions="Center"/>
                                            </Frame>
                                            <Label Grid.Column="1"
                                                   Text="{Binding DeliveryID}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="2"
                                                   Text="View"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Info}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
