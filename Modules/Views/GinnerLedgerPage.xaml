<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MadinaEnterprises.Modules.Views.GinnerLedgerPage"
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False"
             MinimumHeightRequest="600"
             MinimumWidthRequest="1200">

    <Grid ColumnDefinitions="260,*">

        <!-- Sidebar -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SidebarBackground}">
            <Grid RowDefinitions="Auto,*,Auto" Padding="16,24">
                <VerticalStackLayout Grid.Row="0" Spacing="14" Margin="8,0,8,24">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Frame BackgroundColor="#1E293B" BorderColor="#334155"
                               CornerRadius="10" Padding="8" HasShadow="False"
                               HeightRequest="42" WidthRequest="42">
                            <Image Source="madina_logo.png" Aspect="AspectFit"/>
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                            <Label Text="MADINA" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource SidebarBrandText}"
                                   FontSize="14" CharacterSpacing="3"/>
                            <Label Text="Enterprises"
                                   TextColor="{StaticResource SidebarBrandAccent}"
                                   FontSize="11" CharacterSpacing="2"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="WORKSPACE" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,0,0,6"/>
                        <Button Text="Dashboard"  Style="{StaticResource SidebarItem}" Clicked="OnDashboardPageButtonClicked"/>
                        <Button Text="Ginners"    Style="{StaticResource SidebarItem}" Clicked="OnGinnersPageButtonClicked"/>
                        <Button Text="Mills"      Style="{StaticResource SidebarItem}" Clicked="OnMillsPageButtonClicked"/>
                        <Button Text="Contracts"  Style="{StaticResource SidebarItem}" Clicked="OnContractsPageButtonClicked"/>
                        <Button Text="Deliveries" Style="{StaticResource SidebarItem}" Clicked="OnDeliveriesPageButtonClicked"/>
                        <Button Text="Payments"   Style="{StaticResource SidebarItem}" Clicked="OnPaymentsPageButtonClicked"/>

                        <Label Text="REPORTS" TextColor="{StaticResource SidebarSectionLabel}"
                               FontFamily="OpenSansSemibold" FontSize="10"
                               CharacterSpacing="2" Margin="12,16,0,6"/>
                        <Button Text="Ginner Ledger" Style="{StaticResource SidebarItemActive}"/>
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B"/>
                    <Button Text="Log out" Style="{StaticResource SidebarLogout}" Clicked="OnLogOutButtonClicked"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Column="1">

            <!-- ============ SELECTION VIEW ============ -->
            <ScrollView x:Name="SelectionView">
                <VerticalStackLayout Padding="36,32" Spacing="24">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="REPORTING" Style="{StaticResource Eyebrow}"/>
                        <Label Text="Ginner ledger" Style="{StaticResource PageTitle}"/>
                        <Label Text="Select a ginner to view their complete ledger — contracts, deliveries and payments in one place."
                               Style="{StaticResource PageSubtitle}"/>
                    </VerticalStackLayout>

                    <Frame Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="Choose a ginner" Style="{StaticResource SectionTitle}"/>

                            <Frame BackgroundColor="{StaticResource Neutral50}"
                                   BorderColor="{StaticResource BorderStrong}"
                                   CornerRadius="10" Padding="4" HasShadow="False">
                                <SearchBar x:Name="ginnerSearchBar"
                                           Placeholder="Search by Ginner Name or Ginner ID..."
                                           TextChanged="OnGinnerSearchTextChanged"
                                           BackgroundColor="Transparent"/>
                            </Frame>

                            <CollectionView x:Name="ginnerListView"
                                            BackgroundColor="Transparent"
                                            HeightRequest="520"
                                            SelectionMode="Single"
                                            SelectionChanged="OnGinnerSelected">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame Style="{StaticResource ListCard}">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  ColumnSpacing="14">
                                                <Frame Grid.RowSpan="3" Grid.Column="0"
                                                       BackgroundColor="{StaticResource Brand50}"
                                                       BorderColor="{StaticResource Brand200}"
                                                       CornerRadius="10"
                                                       Padding="12,10"
                                                       HasShadow="False"
                                                       VerticalOptions="Center">
                                                    <Label Text="G"
                                                           FontFamily="OpenSansSemibold"
                                                           FontSize="20"
                                                           TextColor="{StaticResource Brand700}"
                                                           HorizontalOptions="Center"/>
                                                </Frame>
                                                <Label Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding GinnerName}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="16"
                                                       TextColor="{StaticResource TextPrimary}"/>
                                                <Label Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding Contact}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}"/>
                                                <Label Grid.Row="2" Grid.Column="1"
                                                       Text="{Binding Station}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextMuted}"/>
                                                <Label Grid.RowSpan="3" Grid.Column="2"
                                                       Text="{Binding GinnerID}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="{StaticResource Brand700}"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ============ DETAIL VIEW (Tabs) ============ -->
            <Grid x:Name="DetailView" IsVisible="False"
                  RowDefinitions="Auto,Auto,*"
                  Padding="36,32" RowSpacing="18">

                <!-- Header -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Text="Back"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnBackClicked"
                            VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1"
                                         Padding="16,0,0,0"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="GINNER LEDGER" Style="{StaticResource Eyebrow}"/>
                        <Label x:Name="GinnerNameHeader"
                               Style="{StaticResource PageTitle}"/>
                        <Label x:Name="GinnerInfoHeader"
                               Style="{StaticResource PageSubtitle}"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Tab Bar -->
                <Frame Grid.Row="1"
                       BackgroundColor="{StaticResource SurfaceBackground}"
                       BorderColor="{StaticResource BorderSubtle}"
                       CornerRadius="10"
                       Padding="6"
                       HasShadow="False">
                    <HorizontalStackLayout Spacing="4">
                        <Button x:Name="TabContractsBtn"  Text="Contracts"  CornerRadius="8" Padding="16,8" BackgroundColor="#8AA800" TextColor="White" Clicked="OnTabContractsClicked"/>
                        <Button x:Name="TabDashboardBtn"  Text="Dashboard"  CornerRadius="8" Padding="16,8" BackgroundColor="White"   TextColor="#334155" Clicked="OnTabDashboardClicked"/>
                        <Button x:Name="TabDeliveriesBtn" Text="Deliveries" CornerRadius="8" Padding="16,8" BackgroundColor="White"   TextColor="#334155" Clicked="OnTabDeliveriesClicked"/>
                        <Button x:Name="TabPaymentsBtn"   Text="Payments"   CornerRadius="8" Padding="16,8" BackgroundColor="White"   TextColor="#334155" Clicked="OnTabPaymentsClicked"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Tab Content Host -->
                <Grid Grid.Row="2">

                    <!-- ======== CONTRACTS TAB ======== -->
                    <Grid x:Name="ContractsTab" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0"
                               Text="Edit cells inline and press Save All when you're done."
                               Style="{StaticResource PageSubtitle}"
                               Margin="0,0,0,10"/>
                        <Frame Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                            <ScrollView Orientation="Both">
                                <VerticalStackLayout>
                                    <Grid Style="{StaticResource TableHeaderRow}"
                                          ColumnDefinitions="140,140,80,110,120,110,120,180,180,220">
                                        <Label Grid.Column="0" Text="CONTRACT ID"    Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="1" Text="MILL ID"        Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="2" Text="BALES"          Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="3" Text="PRICE/MAUND"    Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="4" Text="TOTAL AMOUNT"   Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="5" Text="COMMISSION %"   Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="6" Text="DATE CREATED"   Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="7" Text="DELIVERY NOTES" Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="8" Text="PAYMENT NOTES"  Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="9" Text="DESCRIPTION"    Style="{StaticResource TableHeaderLabel}"/>
                                    </Grid>

                                    <VerticalStackLayout x:Name="ContractsGrid" Spacing="1" BackgroundColor="{StaticResource BorderSubtle}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="8,6" ColumnSpacing="8"
                                                      ColumnDefinitions="140,140,80,110,120,110,120,180,180,220"
                                                      BackgroundColor="White">
                                                    <Label Grid.Column="0"  Text="{Binding ContractID}" TextColor="{StaticResource TextPrimary}" VerticalTextAlignment="Center"/>
                                                    <Entry Grid.Column="1"  Text="{Binding MillID, Mode=TwoWay}"/>
                                                    <Entry Grid.Column="2"  Text="{Binding TotalBales, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="3"  Text="{Binding PricePerBatch, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="4"  Text="{Binding TotalAmount, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="5"  Text="{Binding CommissionPercentage, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <DatePicker Grid.Column="6" Date="{Binding DateCreated, Mode=TwoWay}"/>
                                                    <Entry Grid.Column="7"  Text="{Binding DeliveryNotes, Mode=TwoWay}"/>
                                                    <Entry Grid.Column="8"  Text="{Binding PaymentNotes, Mode=TwoWay}"/>
                                                    <Entry Grid.Column="9"  Text="{Binding Description, Mode=TwoWay}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label x:Name="ContractsEmptyLabel"
                                           Text="No contracts found for this ginner."
                                           Style="{StaticResource Caption}"
                                           Padding="24"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Frame>
                        <HorizontalStackLayout Grid.Row="2" Spacing="10" Margin="0,14,0,0" HorizontalOptions="End">
                            <Button Text="Reload"             Style="{StaticResource SecondaryButton}" Clicked="OnReloadClicked"/>
                            <Button Text="Save all contracts" Style="{StaticResource PrimaryButton}"   Clicked="OnSaveContractsClicked"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- ======== DASHBOARD TAB ======== -->
                    <ScrollView x:Name="DashboardTab" IsVisible="False">
                        <VerticalStackLayout Spacing="18" Padding="0">
                            <Label Text="Cumulative KPIs for this ginner" Style="{StaticResource SectionTitle}"/>

                            <Grid ColumnDefinitions="*,*,*,*"
                                  RowSpacing="14" ColumnSpacing="14"
                                  RowDefinitions="Auto,Auto">

                                <Frame Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="TOTAL CONTRACTS" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiContractsLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource TextPrimary}"/>
                                    </VerticalStackLayout>
                                </Frame>
                                <Frame Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="TOTAL BALES" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiBalesLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource TextPrimary}"/>
                                    </VerticalStackLayout>
                                </Frame>
                                <Frame Grid.Row="0" Grid.Column="2" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="TOTAL DEAL AMOUNT" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiDealAmountLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource TextPrimary}"/>
                                    </VerticalStackLayout>
                                </Frame>
                                <Frame Grid.Row="0" Grid.Column="3" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="TOTAL COMMISSION" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiCommissionLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource Brand600}"/>
                                    </VerticalStackLayout>
                                </Frame>

                                <Frame Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="PAYMENTS MADE" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiPaidLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource Success}"/>
                                    </VerticalStackLayout>
                                </Frame>
                                <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="PAYMENTS DUE" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiDueLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource Warning}"/>
                                    </VerticalStackLayout>
                                </Frame>
                                <Frame Grid.Row="1" Grid.Column="2" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="TOTAL DELIVERIES" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiDeliveriesLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource TextPrimary}"/>
                                    </VerticalStackLayout>
                                </Frame>
                                <Frame Grid.Row="1" Grid.Column="3" Style="{StaticResource StatCard}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="AVG. COMMISSION" Style="{StaticResource Eyebrow}"/>
                                        <Label x:Name="KpiAvgCommissionLabel" FontFamily="OpenSansSemibold" FontSize="22" TextColor="{StaticResource Brand600}"/>
                                    </VerticalStackLayout>
                                </Frame>
                            </Grid>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- ======== DELIVERIES TAB ======== -->
                    <Grid x:Name="DeliveriesTab" IsVisible="False" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0"
                               Text="Deliveries for this ginner's contracts (edit cells, then press Save All)."
                               Style="{StaticResource PageSubtitle}"
                               Margin="0,0,0,10"/>
                        <Frame Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                            <ScrollView Orientation="Both">
                                <VerticalStackLayout>
                                    <Grid Style="{StaticResource TableHeaderRow}"
                                          ColumnDefinitions="140,140,110,80,110,110,140,160,130,130">
                                        <Label Grid.Column="0" Text="DELIVERY ID"    Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="1" Text="CONTRACT ID"    Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="2" Text="AMOUNT"         Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="3" Text="BALES"          Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="4" Text="FACTORY WT"     Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="5" Text="MILL WT"        Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="6" Text="TRUCK #"        Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="7" Text="DRIVER CONTACT" Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="8" Text="DEPARTURE"      Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="9" Text="DELIVERED"      Style="{StaticResource TableHeaderLabel}"/>
                                    </Grid>

                                    <VerticalStackLayout x:Name="DeliveriesGrid" Spacing="1" BackgroundColor="{StaticResource BorderSubtle}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="8,6" ColumnSpacing="8"
                                                      ColumnDefinitions="140,140,110,80,110,110,140,160,130,130"
                                                      BackgroundColor="White">
                                                    <Label Grid.Column="0" Text="{Binding DeliveryID}" TextColor="{StaticResource TextPrimary}" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="1" Text="{Binding ContractID}" TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center"/>
                                                    <Entry Grid.Column="2" Text="{Binding Amount, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="3" Text="{Binding TotalBales, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="4" Text="{Binding FactoryWeight, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="5" Text="{Binding MillWeight, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="6" Text="{Binding TruckNumber, Mode=TwoWay}"/>
                                                    <Entry Grid.Column="7" Text="{Binding DriverContact, Mode=TwoWay}"/>
                                                    <DatePicker Grid.Column="8" Date="{Binding DepartureDate, Mode=TwoWay}"/>
                                                    <DatePicker Grid.Column="9" Date="{Binding DeliveryDate, Mode=TwoWay}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label x:Name="DeliveriesEmptyLabel"
                                           Text="No deliveries found for this ginner."
                                           Style="{StaticResource Caption}"
                                           Padding="24"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Frame>
                        <HorizontalStackLayout Grid.Row="2" Spacing="10" Margin="0,14,0,0" HorizontalOptions="End">
                            <Button Text="Reload"              Style="{StaticResource SecondaryButton}" Clicked="OnReloadClicked"/>
                            <Button Text="Save all deliveries" Style="{StaticResource PrimaryButton}"   Clicked="OnSaveDeliveriesClicked"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- ======== PAYMENTS TAB ======== -->
                    <Grid x:Name="PaymentsTab" IsVisible="False" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0"
                               Text="Payments for this ginner's contracts (edit cells, then press Save All)."
                               Style="{StaticResource PageSubtitle}"
                               Margin="0,0,0,10"/>
                        <Frame Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                            <ScrollView Orientation="Both">
                                <VerticalStackLayout>
                                    <Grid Style="{StaticResource TableHeaderRow}"
                                          ColumnDefinitions="140,140,130,130,80,130,160">
                                        <Label Grid.Column="0" Text="PAYMENT ID"     Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="1" Text="CONTRACT ID"    Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="2" Text="TOTAL AMOUNT"   Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="3" Text="AMOUNT PAID"    Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="4" Text="BALES"          Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="5" Text="DATE"           Style="{StaticResource TableHeaderLabel}"/>
                                        <Label Grid.Column="6" Text="TRANSACTION ID" Style="{StaticResource TableHeaderLabel}"/>
                                    </Grid>

                                    <VerticalStackLayout x:Name="PaymentsGrid" Spacing="1" BackgroundColor="{StaticResource BorderSubtle}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="8,6" ColumnSpacing="8"
                                                      ColumnDefinitions="140,140,130,130,80,130,160"
                                                      BackgroundColor="White">
                                                    <Label Grid.Column="0" Text="{Binding PaymentID}" TextColor="{StaticResource TextPrimary}" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="1" Text="{Binding ContractID}" TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center"/>
                                                    <Entry Grid.Column="2" Text="{Binding TotalAmount, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="3" Text="{Binding AmountPaid, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <Entry Grid.Column="4" Text="{Binding TotalBales, Mode=TwoWay}" Keyboard="Numeric"/>
                                                    <DatePicker Grid.Column="5" Date="{Binding Date, Mode=TwoWay}"/>
                                                    <Entry Grid.Column="6" Text="{Binding TransactionID, Mode=TwoWay}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label x:Name="PaymentsEmptyLabel"
                                           Text="No payments found for this ginner."
                                           Style="{StaticResource Caption}"
                                           Padding="24"
                                           IsVisible="False"/>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Frame>
                        <HorizontalStackLayout Grid.Row="2" Spacing="10" Margin="0,14,0,0" HorizontalOptions="End">
                            <Button Text="Reload"            Style="{StaticResource SecondaryButton}" Clicked="OnReloadClicked"/>
                            <Button Text="Save all payments" Style="{StaticResource PrimaryButton}"   Clicked="OnSavePaymentsClicked"/>
                        </HorizontalStackLayout>
                    </Grid>

                </Grid>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>
