<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        ==============================================================
          MADINA ENTERPRISES DESIGN TOKENS
          Modern, accessible palette rooted in the Madina lime brand.
          Uses slate neutrals for a professional SaaS feel.
        ==============================================================
    -->

    <!-- Brand (lime / olive) -->
    <Color x:Key="Brand50">#F4F9D9</Color>
    <Color x:Key="Brand100">#E6F0B3</Color>
    <Color x:Key="Brand200">#D1E581</Color>
    <Color x:Key="Brand300">#B8D64C</Color>
    <Color x:Key="Brand400">#A4C400</Color>
    <Color x:Key="Brand500">#8AA800</Color>
    <Color x:Key="Brand600">#6E8700</Color>
    <Color x:Key="Brand700">#566900</Color>
    <Color x:Key="Brand800">#3E4C00</Color>
    <Color x:Key="Brand900">#2A3300</Color>

    <!-- Neutrals (slate scale) -->
    <Color x:Key="Neutral0">#FFFFFF</Color>
    <Color x:Key="Neutral50">#F8FAFC</Color>
    <Color x:Key="Neutral100">#F1F5F9</Color>
    <Color x:Key="Neutral200">#E2E8F0</Color>
    <Color x:Key="Neutral300">#CBD5E1</Color>
    <Color x:Key="Neutral400">#94A3B8</Color>
    <Color x:Key="Neutral500">#64748B</Color>
    <Color x:Key="Neutral600">#475569</Color>
    <Color x:Key="Neutral700">#334155</Color>
    <Color x:Key="Neutral800">#1E293B</Color>
    <Color x:Key="Neutral900">#0F172A</Color>

    <!-- Status colors -->
    <Color x:Key="Success">#16A34A</Color>
    <Color x:Key="SuccessBg">#DCFCE7</Color>
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="WarningBg">#FEF3C7</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="DangerBg">#FEE2E2</Color>
    <Color x:Key="Info">#2563EB</Color>
    <Color x:Key="InfoBg">#DBEAFE</Color>

    <!-- Semantic aliases -->
    <Color x:Key="PageBackground">#F6F8FB</Color>
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>
    <Color x:Key="SurfaceMuted">#F1F5F9</Color>
    <Color x:Key="BorderSubtle">#E2E8F0</Color>
    <Color x:Key="BorderStrong">#CBD5E1</Color>
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#475569</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="TextOnBrand">#FFFFFF</Color>
    <Color x:Key="TextOnDark">#F8FAFC</Color>

    <!-- Sidebar tokens (dark navigation rail) -->
    <Color x:Key="SidebarBackground">#0F172A</Color>
    <Color x:Key="SidebarBorder">#1E293B</Color>
    <Color x:Key="SidebarItemText">#CBD5E1</Color>
    <Color x:Key="SidebarItemHover">#1E293B</Color>
    <Color x:Key="SidebarItemActiveBg">#A4C400</Color>
    <Color x:Key="SidebarItemActiveText">#0F172A</Color>
    <Color x:Key="SidebarSectionLabel">#64748B</Color>
    <Color x:Key="SidebarBrandText">#F8FAFC</Color>
    <Color x:Key="SidebarBrandAccent">#A4C400</Color>

    <!--
        ==============================================================
          LEGACY KEYS
          Preserved so the default MAUI template controls still render
          if they reference these names anywhere.
        ==============================================================
    -->
    <Color x:Key="Primary">#8AA800</Color>
    <Color x:Key="PrimaryDark">#6E8700</Color>
    <Color x:Key="PrimaryDarkText">#F8FAFC</Color>
    <Color x:Key="Secondary">#E6F0B3</Color>
    <Color x:Key="SecondaryDarkText">#566900</Color>
    <Color x:Key="Tertiary">#0F172A</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#0F172A</Color>
    <Color x:Key="Magenta">#8AA800</Color>
    <Color x:Key="MidnightBlue">#0F172A</Color>
    <Color x:Key="OffBlack">#0F172A</Color>

    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#0F172A</Color>
    <Color x:Key="Gray950">#020617</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
