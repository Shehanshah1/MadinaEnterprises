<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        ==============================================================
          MADINA ENTERPRISES · COMPONENT STYLES
        ==============================================================
        Modern, flat, accessible components. All legacy control defaults
        are kept sensible; named styles (x:Key) are provided for the new
        design system.
    -->

    <!-- ==========================================================
         Global defaults (applied to every instance of the target)
         ========================================================== -->

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineBreakMode" Value="WordWrap"/>
    </Style>

    <Style TargetType="Span">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Brand500}" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{StaticResource Neutral200}"/>
        <Setter Property="SelectedIndicatorColor" Value="{StaticResource Brand500}"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource BorderSubtle}" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource BorderSubtle}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <Style TargetType="Frame">
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderSubtle}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource TextOnBrand}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Brand500}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="MinimumHeightRequest" Value="40"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                            <Setter Property="BackgroundColor" Value="{StaticResource Neutral200}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="42"/>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="72"/>
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Brand500}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource Brand500}" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource Brand500}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource Neutral200}" />
        <Setter Property="ThumbColor" Value="{StaticResource Brand500}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Brand500}" />
        <Setter Property="ThumbColor" Value="#FFFFFF" />
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource Brand500}" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="SeparatorColor" Value="{StaticResource BorderSubtle}" />
        <Setter Property="RefreshControlColor" Value="{StaticResource Brand500}" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style TargetType="CollectionView">
        <Setter Property="BackgroundColor" Value="Transparent"/>
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource SurfaceBackground}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="IconColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- ==========================================================
         Typography
         ========================================================== -->

    <Style TargetType="Label" x:Key="Display">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style TargetType="Label" x:Key="PageTitle">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style TargetType="Label" x:Key="PageSubtitle">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style TargetType="Label" x:Key="SectionTitle">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style TargetType="Label" x:Key="Caption">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style TargetType="Label" x:Key="Eyebrow">
        <Setter Property="TextColor" Value="{StaticResource Brand600}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CharacterSpacing" Value="2"/>
    </Style>

    <Style TargetType="Label" x:Key="FormLabel">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Legacy headline style, remapped to modern look -->
    <Style TargetType="Label" x:Key="Headline" BasedOn="{StaticResource PageTitle}"/>
    <Style TargetType="Label" x:Key="SubHeadline" BasedOn="{StaticResource SectionTitle}"/>

    <!-- ==========================================================
         Surfaces · Cards
         ========================================================== -->

    <Style TargetType="Frame" x:Key="Card">
        <Setter Property="HasShadow" Value="False"/>
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <Style TargetType="Frame" x:Key="CardCompact" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="14"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style TargetType="Frame" x:Key="StatCard" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="18"/>
    </Style>

    <Style TargetType="Frame" x:Key="ListCard">
        <Setter Property="HasShadow" Value="False"/>
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- ==========================================================
         Buttons (named variants)
         ========================================================== -->

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Brand500}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBackground}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="1"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderStrong}"/>
    </Style>

    <Style TargetType="Button" x:Key="GhostButton">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style TargetType="Button" x:Key="DangerButton">
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Danger}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style TargetType="Button" x:Key="WarningButton">
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Warning}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style TargetType="Button" x:Key="InfoButton">
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Info}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style TargetType="Button" x:Key="SuccessButton">
        <Setter Property="TextColor" Value="#FFFFFF"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Success}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="MinimumHeightRequest" Value="42"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <!-- ==========================================================
         Sidebar navigation items
         ========================================================== -->

    <Style TargetType="Button" x:Key="SidebarItem">
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="TextColor" Value="{StaticResource SidebarItemText}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="ContentLayout" Value="Left,10"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource SidebarItemHover}"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="SidebarItemActive" BasedOn="{StaticResource SidebarItem}">
        <Setter Property="BackgroundColor" Value="{StaticResource SidebarItemActiveBg}"/>
        <Setter Property="TextColor" Value="{StaticResource SidebarItemActiveText}"/>
    </Style>

    <Style TargetType="Button" x:Key="SidebarLogout" BasedOn="{StaticResource SidebarItem}">
        <Setter Property="TextColor" Value="#F87171"/>
    </Style>

    <!-- ==========================================================
         Section divider
         ========================================================== -->

    <Style TargetType="BoxView" x:Key="Divider">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="BackgroundColor" Value="{StaticResource BorderSubtle}"/>
    </Style>

    <Style TargetType="BoxView" x:Key="DividerVertical">
        <Setter Property="WidthRequest" Value="1"/>
        <Setter Property="BackgroundColor" Value="{StaticResource BorderSubtle}"/>
    </Style>

    <!-- ==========================================================
         Table row styles (used in GinnerLedger grids)
         ========================================================== -->

    <Style TargetType="Grid" x:Key="TableHeaderRow">
        <Setter Property="BackgroundColor" Value="{StaticResource Neutral100}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="ColumnSpacing" Value="8"/>
    </Style>

    <Style TargetType="Label" x:Key="TableHeaderLabel">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CharacterSpacing" Value="1"/>
    </Style>

</ResourceDictionary>
